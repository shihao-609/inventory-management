/* 设置页面样式 - 现代简洁风格 */
.container {
  min-height: 100vh;
  background-color: #f8fafc;
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* 区块 */
.section {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.add-btn {
  font-size: 26rpx;
  color: #6366f1;
  padding: 12rpx 24rpx;
  background-color: rgba(99, 102, 241, 0.1);
  border-radius: 12rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.add-btn:active {
  background-color: rgba(99, 102, 241, 0.2);
}

/* 字段列表 */
.field-list {
  padding: 0 32rpx;
}

.field-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.field-item:last-child {
  border-bottom: none;
}

.field-info {
  flex: 1;
}

.field-key {
  font-size: 28rpx;
  color: #1e293b;
  font-family: monospace;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.field-label {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

.field-badges {
  display: flex;
  gap: 12rpx;
}

.badge {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.badge.required {
  background-color: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
}

.badge.enabled {
  background-color: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.badge.disabled {
  background-color: #f1f5f9;
  color: #94a3b8;
}

.field-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-icon {
  font-size: 24rpx;
  color: #6366f1;
  padding: 12rpx 16rpx;
  background-color: rgba(99, 102, 241, 0.1);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.action-icon:active {
  background-color: rgba(99, 102, 241, 0.2);
}

.action-icon.danger {
  color: #ef4444;
  background-color: rgba(239, 68, 68, 0.1);
}

.action-icon.danger:active {
  background-color: rgba(239, 68, 68, 0.2);
}

/* 菜单项 */
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item text:first-child {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
}

.menu-item .arrow {
  font-size: 26rpx;
  color: #94a3b8;
}

.menu-item.danger text:first-child {
  color: #ef4444;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 640rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  z-index: 1000;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border-bottom: 1rpx solid #f1f5f9;
  color: #1e293b;
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item .label {
  display: block;
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input-field {
  width: 100%;
  padding: 24rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.input-field:focus {
  border-color: #6366f1;
  background-color: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(99, 102, 241, 0.1);
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-item .label {
  margin-bottom: 0;
}

.warning-text {
  font-size: 28rpx;
  color: #ef4444;
  text-align: center;
  padding: 24rpx 0;
  font-weight: 500;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f1f5f9;
}

.modal-btn {
  flex: 1;
  padding: 28rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.modal-btn.cancel {
  color: #64748b;
  border-right: 1rpx solid #f1f5f9;
}

.modal-btn.cancel:active {
  background-color: #f8fafc;
}

.modal-btn.confirm {
  color: #6366f1;
}

.modal-btn.confirm:active {
  background-color: rgba(99, 102, 241, 0.1);
}

.modal-btn.danger {
  color: #ef4444;
}

.modal-btn.danger:active {
  background-color: rgba(239, 68, 68, 0.1);
}
