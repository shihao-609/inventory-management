.container {
  padding: 24rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.permission-info {
  background-color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
}

.info-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.form-card {
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  padding: 24rpx;
}

.form-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 16rpx;
}

.account-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.account-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  border: 1rpx solid #f0f0f0;
}

.account-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #e6e6e6;
}

.account-nickname {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.account-role {
  font-size: 24rpx;
  color: #999;
  background-color: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.account-master {
  font-size: 24rpx;
  color: #fff;
  background-color: #1890ff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.account-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  min-width: 180rpx;
}

.action-btn.transfer {
  background-color: #1890ff;
  color: #fff;
  border: none;
}

.action-btn.transfer:disabled {
  background-color: #d9d9d9;
  color: #fff;
}

.empty-list {
  text-align: center;
  padding: 48rpx 0;
  color: #999;
  font-size: 28rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  background-color: #fff;
  border-radius: 12rpx;
  width: 80%;
  max-width: 500rpx;
  padding: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-body {
  margin-bottom: 32rpx;
}

.modal-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  line-height: 1.4;
  text-align: center;
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 16rpx 0;
  border-radius: 8rpx;
}

.modal-btn.cancel {
  background-color: #f5f5f5;
  color: #333;
  border: 1rpx solid #d9d9d9;
}

.modal-btn.confirm {
  background-color: #1890ff;
  color: #fff;
  border: none;
}

.modal-btn.confirm:disabled {
  background-color: #d9d9d9;
  color: #fff;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  background-color: rgba(0, 0, 0, 0.7);
  padding: 32rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top: 4rpx solid #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  color: #fff;
  font-size: 28rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 响应式调整 */
@media (max-width: 375px) {
  .container {
    padding: 16rpx;
  }
  
  .page-title {
    font-size: 28rpx;
  }
  
  .info-text {
    font-size: 24rpx;
  }
  
  .account-item {
    flex-direction: column;
    align-items: flex-start;
    gap: 12rpx;
  }
  
  .account-actions {
    align-self: flex-end;
  }
}