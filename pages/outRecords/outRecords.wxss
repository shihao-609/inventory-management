/* 出库记录页面样式 - 现代简洁风格 */

.container {
  min-height: 100vh;
  background-color: #f8fafc;
  display: flex;
  flex-direction: column;
}

/* 搜索栏 */
.search-bar {
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  margin: 24rpx;
  margin-bottom: 0;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-input {
  width: 100%;
  padding: 20rpx 28rpx;
  background-color: #f1f5f9;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.search-input:focus {
  border-color: #6366f1;
  background-color: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(99, 102, 241, 0.1);
}

/* 记录列表 */
.record-list {
  flex: 1;
  padding: 24rpx;
}

/* 记录项 */
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
  transition: all 0.2s ease;
}

.record-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.record-main {
  flex: 1;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.out-quantity {
  font-size: 36rpx;
  font-weight: 700;
  color: #ef4444;
}

.record-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-code {
  font-size: 22rpx;
  color: #94a3b8;
  font-family: monospace;
}

.out-time {
  font-size: 22rpx;
  color: #64748b;
}

/* 剩余库存 */
.record-stock {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-left: 24rpx;
  border-left: 1rpx solid #f1f5f9;
  margin-left: 24rpx;
}

.stock-label {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 8rpx;
}

.stock-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #10b981;
}

.stock-value.warning {
  color: #ef4444;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state text {
  color: #94a3b8;
  font-size: 28rpx;
}

/* 加载状态 */
.loading, .loading-more, .no-more {
  text-align: center;
  padding: 40rpx;
  color: #94a3b8;
  font-size: 26rpx;
}

.no-more {
  color: #cbd5e1;
}
