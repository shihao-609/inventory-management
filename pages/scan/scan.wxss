/* 扫描录入页面样式 - 现代简洁风格 */

/* 全局容器 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8fafc;
  overflow: hidden;
  position: relative;
  /* 防止页面抖动 */
  -webkit-overflow-scrolling: auto;
  /* 硬件加速优化 */
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}





/* 可滚动内容区域 */
.scroll-content {
  flex: 1;
  padding: 16rpx 20rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-y: auto;
  position: relative;
  z-index: 1;
  -webkit-overflow-scrolling: touch;
  /* 防止内容抖动 */
  scroll-behavior: smooth;
  overscroll-behavior: contain;
  /* 硬件加速 */
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
  will-change: scroll-position;
}

/* 卡片通用样式 */
.card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

/* 识别结果区 */
.goods-status {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #10b981, #34d399);
  color: #ffffff;
  font-weight: 500;
}

/* 物品编号 textarea */
.scan-input-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.textarea-wrapper {
  flex: 1;
  margin-bottom: 0;
}

.textarea-field {
  width: 100%;
  min-height: 88rpx;
  padding: 20rpx;
  background-color: #f8fafc;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1e293b;
  box-sizing: border-box;
  border: 2rpx solid #e2e8f0;
  line-height: 1.5;
  transition: all 0.2s ease;
}

.textarea-field:focus {
  border-color: #6366f1;
  background-color: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(99, 102, 241, 0.1);
}

.textarea-field[disabled] {
  background-color: #f1f5f9;
  color: #94a3b8;
}

/* 扫码按钮 */
.btn-rescan-wrapper {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 16rpx;
}

.btn-rescan {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #ffffff;
  border: none;
  border-radius: 28rpx;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.3);
  transition: all 0.2s ease;
}

.btn-rescan:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.3);
}

/* 行内重新扫码按钮 */
.btn-rescan-inline {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.3);
  transition: all 0.2s ease;
  white-space: nowrap;
  height: fit-content;
  margin-top: 0;
}

.btn-rescan-inline:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.3);
}

.btn-rescan.btn-query {
  background: linear-gradient(135deg, #10b981, #34d399);
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.3);
}



/* 手动入库模式主输入框样式 */
.input-wrapper {
  margin-bottom: 16rpx;
}

.main-name-input {
  height: 88rpx;
  font-size: 30rpx;
  background-color: #eef2ff;
  border: 2rpx solid #c7d2fe;
}

/* 可搜索下拉选择器 - 固定定位容器 */
.search-picker-wrapper {
  position: relative;
  margin-bottom: 16rpx;
  z-index: 10;
}

.search-picker-input {
  position: relative;
  display: flex;
  align-items: center;
  z-index: 11;
}

.search-picker-input input {
  padding-right: 60rpx;
  height: 88rpx;
  font-size: 30rpx;
  background-color: #eef2ff;
  border: 2rpx solid #c7d2fe;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.search-picker-input.active input {
  border-color: #6366f1;
  background-color: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(99, 102, 241, 0.1);
}

.picker-arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20rpx;
  color: #6366f1;
  transition: transform 0.3s ease;
  z-index: 12;
}

.picker-arrow.up {
  transform: translateY(-50%) rotate(180deg);
}

/* 下拉列表 - 固定定位不抖动 */
.search-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border: 2rpx solid #e2e8f0;
  border-top: none;
  border-radius: 0 0 16rpx 16rpx;
  height: 0;
  overflow: hidden;
  opacity: 0;
  visibility: hidden;
  z-index: 100;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  margin-top: -4rpx;
}

.search-dropdown.show {
  height: auto;
  max-height: 400rpx;
  overflow-y: auto;
  opacity: 1;
  visibility: visible;
}

/* 下拉列表项 */
.dropdown-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item.selected {
  background-color: rgba(99, 102, 241, 0.08);
}

.dropdown-item:active {
  background-color: #f8fafc;
}

.item-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-name {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
}

.item-stock {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 500;
}

.item-code {
  font-size: 22rpx;
  color: #94a3b8;
  font-family: monospace;
}

/* 空状态 */
.dropdown-empty {
  padding: 48rpx 24rpx;
  text-align: center;
}

.dropdown-empty text {
  font-size: 26rpx;
  color: #94a3b8;
}

/* 商品信息区 */
.form-item {
  margin-bottom: 28rpx;
}

.form-item .label {
  display: block;
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-item .required {
  color: #ef4444;
}

/* 物品编号显示样式（只读） */
.item-code-display {
  padding: 24rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
}

.item-code-value {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
}

.item-code-value.placeholder {
  color: #94a3b8;
}

/* 表单元素间距 */
.form-item {
  margin-bottom: 16rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item .label {
  display: block;
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 8rpx;
  font-weight: 500;
}

/* 输入框样式 */
.input-field {
  width: 100%;
  padding: 16rpx 20rpx;
  background-color: #f8fafc;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1e293b;
  box-sizing: border-box;
  border: 2rpx solid #e2e8f0;
  height: 80rpx;
  line-height: 80rpx;
  transition: all 0.2s ease;
}

.input-field:focus {
  border-color: #6366f1;
  background-color: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(99, 102, 241, 0.1);
}

.input-field.input-disabled {
  background-color: #f1f5f9;
  color: #64748b;
}

.input-field::placeholder {
  color: #94a3b8;
}

.input-field.input-error {
  border-color: #ef4444;
  background-color: #fef2f2;
}

.error-message {
  font-size: 24rpx;
  color: #ef4444;
  margin-top: 8rpx;
  display: block;
}

/* 库存相关 */
.stock-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.stock-header .switch-label {
  margin-left: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.stock-edit-wrapper {
  margin-top: 12rpx;
}

.stock-change-wrapper {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stock-input {
  background-color: #fffbeb;
  border: 2rpx solid #fcd34d;
}

.stock-current, .stock-hint {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 8rpx;
  display: block;
}

/* 本次进货数量输入框样式 */
.purchase-quantity-wrapper {
  margin-top: 12rpx;
}

.stock-display {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: #f8fafc;
  border-radius: 12rpx;
  border: 2rpx solid #e2e8f0;
}

/* 物品查询模式库存显示样式 */
.stock-query-display {
  cursor: pointer;
  transition: all 0.2s ease;
}

.stock-query-display:active {
  background-color: #eef2ff;
  border-color: #c7d2fe;
}

.stock-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
}

.stock-num.stock-warning {
  color: #ef4444;
}

.stock-unit {
  font-size: 26rpx;
  color: #64748b;
  margin-left: 12rpx;
}

/* 库存不足警示标签 */
.warning-tag {
  margin-left: 20rpx;
  padding: 8rpx 16rpx;
  background-color: #fef2f2;
  border: 2rpx solid #fecaca;
  border-radius: 12rpx;
}

.warning-tag text {
  font-size: 22rpx;
  color: #ef4444;
  font-weight: 500;
}

/* 售价显示 */
.price-display {
  padding: 16rpx 20rpx;
  background-color: #f8fafc;
  border-radius: 12rpx;
  border: 2rpx solid #e2e8f0;
}

.price-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #6366f1;
}

/* 进价相关 */
.cost-price-item {
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
}

.collapse-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  cursor: pointer;
}

.collapse-header .label {
  margin-bottom: 0;
}

.collapse-arrow {
  font-size: 20rpx;
  color: #64748b;
  transition: transform 0.3s ease;
}

.collapse-arrow.up {
  transform: rotate(180deg);
}

.collapse-content {
  margin-top: 16rpx;
}

/* 查看进价按钮 */
.view-cost-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx dashed #cbd5e1;
}

.view-cost-btn text {
  font-size: 26rpx;
  color: #6366f1;
  font-weight: 500;
}

/* 进价显示 */
.cost-display {
  padding: 24rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
}

.cost-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #10b981;
}

/* 提示文字 */
.stock-hint {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 12rpx;
}

/* 滚动底部安全间距 - 确保内容不被底部按钮遮挡 */
.scroll-bottom-space {
  height: 160rpx;
  min-height: 160rpx;
}

/* 底部操作栏 */
.btn-group {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  padding: 12rpx 20rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  gap: 12rpx;
  z-index: 50;
}

.btn-save {
  flex: 1;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.3);
  min-height: 64rpx;
  line-height: 64rpx;
  transition: all 0.2s ease;
}

.btn-save:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.3);
}

.btn-back {
  flex: 1;
  background-color: #f1f5f9;
  color: #64748b;
  border: none;
  border-radius: 16rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  min-height: 64rpx;
  line-height: 64rpx;
  transition: all 0.2s ease;
}

.btn-back:active {
  background-color: #e2e8f0;
}

/* 出库按钮样式 */
.btn-out {
  flex: 1;
  background: linear-gradient(135deg, #ef4444, #f97316);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.3);
  min-height: 64rpx;
  line-height: 64rpx;
  transition: all 0.2s ease;
}

.btn-out:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.3);
}

/* switch 样式覆盖 */
.wx-switch .wx-switch-checkbox {
  background-color: #e2e8f0;
}

.wx-switch .wx-switch-checkbox-checked {
  background-color: #6366f1 !important;
}

/* 位置选择器样式 */
.position-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}

.position-selector text {
  flex: 1;
}

.position-selector .placeholder {
  color: #94a3b8;
}

.position-selector::after {
  content: '▼';
  font-size: 18rpx;
  color: #6366f1;
  margin-left: 12rpx;
}

/* ========== 出库弹窗样式 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 560rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  animation: modalSlideUp 0.3s ease;
}

@keyframes modalSlideUp {
  from {
    transform: translateY(50rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  padding: 32rpx 40rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid #f1f5f9;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.modal-body {
  padding: 32rpx 40rpx;
}

.modal-form-item {
  margin-bottom: 28rpx;
}

.modal-form-item:last-child {
  margin-bottom: 0;
}

.modal-label {
  display: block;
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.modal-switch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.modal-switch-header .modal-label {
  margin-bottom: 0;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #f8fafc;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1e293b;
  box-sizing: border-box;
  border: 2rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.modal-input:focus {
  border-color: #6366f1;
  background-color: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(99, 102, 241, 0.1);
}

.modal-input.readonly {
  background-color: #f1f5f9;
  color: #64748b;
  border-color: #e2e8f0;
}

.modal-input.editable {
  background-color: #ffffff;
  border-color: #6366f1;
}

.modal-hint {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  display: block;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f1f5f9;
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  border: none;
  background-color: transparent;
  border-radius: 0;
  padding: 0;
  margin: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  color: #64748b;
  border-right: 1rpx solid #f1f5f9;
}

.modal-btn-cancel:active {
  background-color: #f8fafc;
}

.modal-btn-confirm {
  color: #6366f1;
  font-weight: 600;
}

.modal-btn-confirm:active {
  background-color: #f8fafc;
}
